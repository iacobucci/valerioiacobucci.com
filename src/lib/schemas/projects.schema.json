{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["title", "github_repo", "tech"],
    "properties": {
      "title": { "type": "string" },
      "github_repo": { "type": "string" },
      "website_url": { "type": "string" },
      "tech": { 
        "type": "array", 
        "items": { "type": "string" } 
      },
      "selected": { "type": "boolean", "default": false }
    }
  }
}
